#!/bin/sh
# MXKeys prepare-commit-msg hook.
#
# Strip auto-generated attribution trailers appended by some editors
# and tooling. Runs before commit-msg so the message is normalized
# prior to policy validation.
#
# Install (per clone): git config core.hooksPath .githooks

set -eu

FILE="${1:-}"
[ -f "$FILE" ] || exit 0

TMP="$(mktemp)"
awk '
    { lines[NR] = $0 }
    END {
        end = NR
        while (end > 0) {
            line = lines[end]
            if (line == "" \
                || line ~ /^[[:space:]]*[Mm]ade-with:/ \
                || line ~ /^[[:space:]]*[Gg]enerated-by:/ \
                || line ~ /^[[:space:]]*[Aa]uthored-by:/) {
                end--
            } else {
                break
            }
        }
        for (i = 1; i <= end; i++) print lines[i]
    }
' "$FILE" > "$TMP"
mv "$TMP" "$FILE"
